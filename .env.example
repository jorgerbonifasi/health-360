# =============================================================================
# Health 360 — Edge Function / backend secrets
# =============================================================================
# These are set as Supabase Edge Function secrets (supabase secrets set ...), NOT committed.
# The frontend has its own web/.env.example (only VITE_-prefixed, browser-safe vars).

# --- Supabase (service role bypasses RLS; used by all Edge Functions) ---------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role key (Project Settings → API). SECRET. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Strava (https://www.strava.com/settings/api) -----------------------------
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET
# Any random string you choose; must match what you register with the webhook subscription.
STRAVA_VERIFY_TOKEN=pick-a-random-string
# Where Strava sends you back after OAuth (this function URL):
STRAVA_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/oauth-callback?provider=strava

# --- Withings (https://developer.withings.com) --------------------------------
WITHINGS_CLIENT_ID=YOUR_WITHINGS_CLIENT_ID
WITHINGS_CLIENT_SECRET=YOUR_WITHINGS_CLIENT_SECRET
WITHINGS_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/oauth-callback?provider=withings

# --- Apple Health (Health Auto Export) ----------------------------------------
# Shared secret protecting the public step-ingestion endpoint. Pick a long random string and
# put the same value in the Health Auto Export request (?token=... or X-Token header).
APPLE_HEALTH_TOKEN=pick-a-long-random-string
