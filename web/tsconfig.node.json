{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // Composite projects must emit; keep the emitted JS/decls out of the source tree.
    "outDir": "./node_modules/.tmp/tsnode",
    "tsBuildInfoFile": "./node_modules/.tmp/tsnode/.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
